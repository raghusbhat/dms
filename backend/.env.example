# ==========================================================================
# DMS Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ==========================================================================

# --------------------------------------------------------------------------
# Database (required)
# --------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dms

# --------------------------------------------------------------------------
# Security (required)
# Generate a new key: openssl rand -hex 32
# --------------------------------------------------------------------------
SECRET_KEY=change-me-before-production

# --------------------------------------------------------------------------
# Environment
# --------------------------------------------------------------------------
ENVIRONMENT=development

# --------------------------------------------------------------------------
# LibreOffice — path to soffice executable
# Used for converting DOCX, XLSX, PPTX → PDF
# Windows default shown. Change for Linux/Mac.
# --------------------------------------------------------------------------
LIBREOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe

# --------------------------------------------------------------------------
# Storage backend
# local     = saves files to backend/data/ folder (default for dev)
# minio     = saves to MinIO (docker-compose includes MinIO)
# s3        = saves to AWS S3 or Cloudflare R2 (production)
# --------------------------------------------------------------------------
STORAGE_BACKEND=local

# MinIO settings (only needed if STORAGE_BACKEND=minio)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=dms-documents
MINIO_SECURE=false

# S3 settings (only needed if STORAGE_BACKEND=s3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# S3_BUCKET=dms-documents

# --------------------------------------------------------------------------
# Redis — background job queue (Celery)
# Required for Phase 1+ (background document processing)
# docker-compose starts Redis automatically
# --------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --------------------------------------------------------------------------
# AI Provider
# gemini  = uses Google Gemini API (default, best quality)
# ollama  = uses local Ollama (free, private, runs on your machine)
# --------------------------------------------------------------------------
AI_PROVIDER=gemini

# Gemini API key (only needed if AI_PROVIDER=gemini)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Ollama URL (only needed if AI_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# --------------------------------------------------------------------------
# Meilisearch — full-text search (Phase 10)
# docker-compose starts Meilisearch automatically
# --------------------------------------------------------------------------
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=dev-master-key-change-in-production

# --------------------------------------------------------------------------
# Email — for notifications (Phase 10)
# In dev, use Mailhog (docker-compose starts it automatically)
# SMTP:    localhost:1025
# Web UI:  http://localhost:8025
# --------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=dms@localhost
